# Public base URL of the deployed app (no trailing slash). Quick Auth binds to this domain.
NEXT_PUBLIC_URL=http://localhost:3000

# Upstash Redis (required for horoscope cache, trades, boards, chat, notifications)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Claude API key for daily horoscope copy. Optional: when unset the deterministic
# template fallback is used instead.
ANTHROPIC_API_KEY=

# Base mainnet RPC used server-side for trade verification and ownership reads.
BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Secret required by /api/cron/* routes (set the same value in Vercel cron headers).
CRON_SECRET=

# Base Builder Code attribution suffix (optional).
NEXT_PUBLIC_BASE_BUILDER_CODE=

# Farcaster account association for the manifest (generate via Base Build / manifest tool).
FARCASTER_ASSOCIATION_HEADER=
FARCASTER_ASSOCIATION_PAYLOAD=
FARCASTER_ASSOCIATION_SIGNATURE=

# Hub endpoint used to verify manifest webhook signatures.
FARCASTER_HUB_URL=

# Set to "production" to make the manifest indexable.
NEXT_PUBLIC_APP_ENV=development

# Development only: bypass Quick Auth and act as this FID (ignored outside NODE_ENV=development).
DEV_FID=
